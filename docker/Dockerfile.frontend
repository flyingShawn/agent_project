# 前端Dockerfile - 用于构建Vue.js应用镜像

# ==================== 构建阶段 ====================
# 使用Node.js 20作为构建环境
FROM hub-mirror.c.163.com/library/node:20-alpine AS builder

# 设置工作目录
WORKDIR /app

# 复制package文件
COPY agent_frontend/package*.json ./

# 安装依赖
# npm ci: 根据package-lock.json安装，确保版本一致
RUN npm ci

# 复制源代码
COPY agent_frontend/ .

# 构建生产版本
# 这会生成dist目录，包含优化后的静态文件
RUN npm run build

# ==================== 运行阶段 ====================
# 使用Nginx作为Web服务器
FROM hub-mirror.c.163.com/library/nginx:alpine

# 复制自定义Nginx配置
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# 从构建阶段复制构建产物
COPY --from=builder /app/dist /usr/share/nginx/html

# 暴露端口（HTTP默认端口）
EXPOSE 80

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost/ || exit 1

# 启动Nginx
CMD ["nginx", "-g", "daemon off;"]