# ========================================
#   桌管智能体配置文件示例
# ========================================
# 使用方法：复制此文件为 .env 并修改配置

# ========================================
#   大模型配置
# ========================================

# Ollama服务地址
OLLAMA_BASE_URL=http://localhost:11434

# 文本对话模型（用于普通对话和SQL生成）
# 可选模型：
#   - qwen2.5:3b (约2GB，速度快，适合低配置)
#   - qwen2.5:7b (约4.7GB，平衡性能)
#   - qwen2.5:14b (约9GB，效果好，需要更多资源)
#   - qwen3.5:9b (如果Ollama支持)
CHAT_MODEL=qwen2.5:7b

# 视觉模型（用于图片理解和多模态RAG）
# 可选模型：
#   - qwen2.5-vl:3b (约2GB)
#   - qwen2.5-vl:7b (约4.7GB)
VISION_MODEL=qwen2.5-vl:7b

# 是否启用云端API兜底（0=不启用，1=启用）
ENABLE_CLOUD_FALLBACK=0

# ========================================
#   数据库配置（只读）
# ========================================
# 说明：支持MySQL和PostgreSQL，请根据实际情况选择

# 数据库类型：mysql 或 postgresql
DB_TYPE=mysql

# MySQL配置（如果使用MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=desk_management
DB_USER=root
DB_PASSWORD=your_password

# PostgreSQL配置（如果使用PostgreSQL）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=desk_management
# DB_USER=postgres
# DB_PASSWORD=your_password

# 完整的数据库连接URL（可选）
# 如果填写此项，将优先使用此配置
# MySQL格式：mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
# PostgreSQL格式：postgresql://用户名:密码@主机:端口/数据库名
# 注意：密码中的特殊字符需要URL编码
DATABASE_URL=

# ========================================
#   RAG文档问答配置
# ========================================

# 文档目录路径
RAG_DOCS_DIR=./data/docs

# Qdrant向量数据库地址
RAG_QDRANT_URL=http://localhost:6333

# Qdrant本地存储路径
RAG_QDRANT_PATH=./.qdrant_local

# 向量集合名称
RAG_QDRANT_COLLECTION=desk_agent_docs

# 文本嵌入模型
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 混合检索权重（0-1之间，越大向量检索权重越高）
RAG_HYBRID_ALPHA=0.7

# 返回的文档数量
RAG_TOP_K=5

# 候选文档数量（用于重排序）
RAG_CANDIDATE_K=30

# ========================================
#   其他配置
# ========================================

# API访问Token（可选，用于接口鉴权）
CHAT_API_TOKEN=
