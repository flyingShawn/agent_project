# ========================================
#   智能体配置
# ========================================

# 智能体名称（影响知识库路径：data/{AGENT_NAME}/docs 和 data/{AGENT_NAME}/sql）
AGENT_NAME=desk-agent

# ========================================
#   大模型配置
# ========================================

# LLM服务地址（OpenAI兼容协议 /v1/chat/completions）
# 可选后端：
#   - 本地 Ollama:  http://localhost:11434/v1       (无需API Key)
#   - DeepSeek:     https://api.deepseek.com/v1     (需配置LLM_API_KEY)
#   - Qwen 云端:    https://dashscope.aliyuncs.com/compatible-mode/v1  (需配置LLM_API_KEY)
LLM_BASE_URL=http://localhost:11434/v1

# LLM API Key（本地Ollama留空即可，云端服务必填）
LLM_API_KEY=

# Ollama服务地址（仅OllamaChatClient使用，已弃用，建议使用LLM_BASE_URL）
OLLAMA_BASE_URL=http://localhost:11434

# 文本对话模型（用于普通对话和SQL生成）
# 可选模型：
#   - qwen3:14b
#   - qwen3.5:9b (如果Ollama支持)
#   - deepseek-chat (DeepSeek云端)
#   - qwen-plus (Qwen云端)
CHAT_MODEL=qwen3.5:9b

# 视觉模型（用于图片理解和多模态RAG）
# 可选模型：
#   - qwen2.5-vl:7b (约4.7GB)
#   - qwen-vl-plus (Qwen云端视觉模型)
VISION_MODEL=qwen3.5:9b


# ========================================
#   数据库配置（只读）
# ========================================
# 说明：支持MySQL和PostgreSQL，请根据实际情况选择

# 数据库类型：mysql 或 postgresql
DB_TYPE=mysql

# MySQL配置（如果使用MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=desk_management
DB_USER=root
DB_PASSWORD=your_password

# PostgreSQL配置（如果使用PostgreSQL）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=desk_management
# DB_USER=postgres
# DB_PASSWORD=your_password

# 完整的数据库连接URL（可选）
# 如果填写此项，将优先使用此配置
# MySQL格式：mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
# PostgreSQL格式：postgresql://用户名:密码@主机:端口/数据库名
# 注意：密码中的特殊字符需要URL编码
DATABASE_URL=

# ========================================
#   RAG文档问答配置
# ========================================
# 标准问题知识库目录路径
RAG_DOCS_DIR=./data/desk-agent/docs
# Qdrant向量数据库地址
RAG_QDRANT_URL=http://localhost:6333
# Qdrant本地存储路径
RAG_QDRANT_PATH=./.qdrant_local
# 文档知识库向量集合名称
RAG_QDRANT_COLLECTION=desk_agent_docs
# 文本嵌入模型
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 混合检索权重（0-1之间，越大向量检索权重越高）
RAG_HYBRID_ALPHA=0.7
# 返回的文档数量
RAG_TOP_K=5
# 候选文档数量（用于重排序）
RAG_CANDIDATE_K=30

# 向量最低相似度阈值（0-1之间，低于此值的文档将被过滤）
# 建议值：0.5，值越大过滤越严格，不相关文档越少
# 例如：问"糖醋排骨怎么做"时，手机相关文档的余弦相似度可能只有0.3，会被过滤掉
RAG_VECTOR_MIN_SCORE=0.5

# ========================================
#   SQL样本库配置
# ========================================
# SQL查询样本目录路径
RAG_SQL_DIR=./data/desk-agent/sql
# SQL样本库向量集合名称
RAG_SQL_QDRANT_COLLECTION=desk_agent_sql
# SQL样本检索返回数量
RAG_SQL_TOP_K=3
# SQL样本检索候选数量
RAG_SQL_CANDIDATE_K=15

# SQL样本检索混合权重（更偏重语义匹配）
RAG_SQL_HYBRID_ALPHA=0.8

# ========================================
#   其他配置
# ========================================

# SQL查询默认最大行数限制
SQL_MAX_ROWS=500

# CORS允许的前端来源（逗号分隔，生产环境应限制为实际前端域名）
CORS_ORIGINS=http://localhost:3000

# ========================================
#   网络搜索配置
# ========================================

# Tavily搜索API Key（留空则禁用网络搜索功能）
# 申请地址：https://tavily.com/
TAVILY_API_KEY=

# 网络搜索返回结果数量
WEB_SEARCH_MAX_RESULTS=5

# ========================================
#   前端配置（VITE_ 前缀，Vite 构建时自动注入）
# ========================================
# 应用名称（侧边栏顶部显示、网页标题）
VITE_APP_NAME=阳途智能助手
# 应用副标题（顶部标题下方浅色文字）
VITE_APP_SUBTITLE=阳途智能助手为您服务
# 欢迎语
VITE_APP_WELCOME_TEXT=有什么我能帮您的呢？
# 输入框占位文字
VITE_APP_INPUT_PLACEHOLDER=给智能助手发消息
# 快捷选项（逗号分隔）
VITE_QUICK_OPTIONS=查看客户端在线状态,今日远程操作记录,近期开关机日志,老旧资产设备查询,部门设备数量统计,USB使用记录查询
# ========================================